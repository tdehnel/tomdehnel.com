---
const today = new Date();
import { SITE_AUTHOR } from "../consts";
---

<footer>
  <p>&copy; {today.getFullYear()} {SITE_AUTHOR}.</p>
  <p class="links">
    <a href="/rss.xml">RSS</a>
    <span aria-hidden="true">·</span>
    <a href="https://www.linkedin.com/in/tdehnel/" rel="me">LinkedIn</a>
  </p>
</footer>
<style>
  footer {
    padding: 2em 1em 4em 1em;
    color: rgb(var(--gray));
    text-align: center;
  }
  footer p {
    margin: 0 0 0.25em 0;
  }
  .links a {
    color: rgb(var(--gray-dark));
  }
  .links span {
    margin: 0 0.4em;
    color: rgb(var(--gray));
  }
</style>
