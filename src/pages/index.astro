---
import { getCollection } from "astro:content";
import BaseHead from "../components/BaseHead.astro";
import Footer from "../components/Footer.astro";
import FormattedDate from "../components/FormattedDate.astro";
import Header from "../components/Header.astro";
import { SITE_DESCRIPTION, SITE_TITLE } from "../consts";

const posts = (await getCollection("blog", ({ data }) => import.meta.env.DEV || !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 5);
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
    <style>
      main { padding-top: 2em; }
      .intro {
        margin-bottom: 3em;
      }
      .intro h1 {
        margin-bottom: 0.5em;
      }
      .intro p {
        font-size: 1.1em;
        color: rgb(var(--gray-dark));
      }
      .recent h2 {
        font-size: 1.5em;
        margin-bottom: 0.5em;
      }
      .recent ul {
        list-style: none;
        padding: 0;
        margin: 0;
      }
      .recent li {
        margin: 0 0 1.5em 0;
      }
      .recent .post-title {
        font-size: 1.25em;
        margin: 0;
      }
      .recent .post-title a {
        color: rgb(var(--black));
        text-decoration: none;
      }
      .recent .post-title a:hover {
        color: var(--accent);
      }
      .recent .post-date {
        margin: 0;
        font-size: 0.9em;
        color: rgb(var(--gray));
      }
      .more {
        margin-top: 1.5em;
      }
    </style>
  </head>
  <body>
    <Header />
    <main>
      <section class="intro">
        <h1>Tom Dehnel</h1>
        <p>
          I'm an SEO consultant based in San Francisco and South Florida. I write here
          about SEO, AI search, marketing, philosophy, and whatever else has my attention.
        </p>
        <p>
          More on the <a href="/about/">about page</a>.
        </p>
      </section>

      <section class="recent">
        <h2>Recent posts</h2>
        <ul>
          {posts.map((post) => (
            <li>
              <h3 class="post-title">
                <a href={`/blog/${post.id}/`}>{post.data.title}</a>
              </h3>
              <p class="post-date"><FormattedDate date={post.data.date} /></p>
            </li>
          ))}
        </ul>
        <p class="more"><a href="/blog/">All posts &rarr;</a></p>
      </section>
    </main>
    <Footer />
  </body>
</html>
