---
import { getCollection } from "astro:content";
import BaseHead from "../../../components/BaseHead.astro";
import Footer from "../../../components/Footer.astro";
import FormattedDate from "../../../components/FormattedDate.astro";
import Header from "../../../components/Header.astro";
import { SITE_TITLE } from "../../../consts";

export async function getStaticPaths() {
  const allPosts = await getCollection(
    "blog",
    ({ data }) => import.meta.env.DEV || !data.draft,
  );

  // Build a map: lowercase tag slug -> { display, posts[] }
  const byTag = new Map();
  for (const post of allPosts) {
    for (const tag of post.data.tags ?? []) {
      const key = tag.toLowerCase();
      if (!byTag.has(key)) byTag.set(key, { display: tag, posts: [] });
      byTag.get(key).posts.push(post);
    }
  }

  return [...byTag.entries()].map(([tag, { display, posts }]) => ({
    params: { tag },
    props: {
      tagDisplay: display,
      posts: posts.sort(
        (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
      ),
    },
  }));
}

const { tagDisplay, posts } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead
      title={`Posts tagged "${tagDisplay}" — ${SITE_TITLE}`}
      description={`All posts tagged ${tagDisplay}.`}
    />
    <style>
      main { padding-top: 1.5em; }
      h1 { font-size: 2em; margin-bottom: 1em; }
      ul.posts { list-style: none; padding: 0; margin: 0; }
      ul.posts li { margin: 0 0 1.75em 0; }
      .post-title { font-size: 1.25em; margin: 0 0 0.15em 0; }
      .post-title a { color: rgb(var(--black)); text-decoration: none; }
      .post-title a:hover { color: var(--accent); }
      .post-date { margin: 0 0 0.25em 0; color: rgb(var(--gray)); font-size: 0.9em; }
      .post-excerpt { margin: 0; color: rgb(var(--gray-dark)); }
      .back { display: inline-block; margin-top: 2em; color: var(--accent); }
    </style>
  </head>
  <body>
    <Header />
    <main>
      <h1>Tagged: {tagDisplay}</h1>
      <ul class="posts">
        {posts.map((post) => (
          <li>
            <h2 class="post-title">
              <a href={`/blog/${post.id}/`}>{post.data.title}</a>
            </h2>
            <p class="post-date"><FormattedDate date={post.data.date} /></p>
            {post.data.excerpt && <p class="post-excerpt">{post.data.excerpt}</p>}
          </li>
        ))}
      </ul>
      <a class="back" href="/blog/">&larr; All posts</a>
    </main>
    <Footer />
  </body>
</html>
